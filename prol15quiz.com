            rationale: "Οι παρατηρήσεις των ερευνητών για τη μικροβιακή μόλυνση των βουρτσών οδήγησαν στην άποψη ότι η εμπλοκή ή εμβάπτιση των ινών σε χλωρεξιδίνη προστατεύει από τη μικροβιακή μόλυνση. Η χλωρεξιδίνη έχει αντιμικροβιακή δράση στις ίνες για τουλάχιστον 2 εβδομάδες. <br><br><strong>ΣΟΣ: Τα προ-εμβαπτισμένα βουρτσάκια στοχεύουν στη μείωση της μικροβιακής επιμόλυνσης του ίδιου του μέσου.</strong>"
        }
];

    function shuffleOptions(questionObj) {
        let optionsWithIndex = questionObj.options.map((opt, i) => ({ text: opt, originalIndex: i }));
        for (let i = optionsWithIndex.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [optionsWithIndex[i], optionsWithIndex[j]] = [optionsWithIndex[j], optionsWithIndex[i]];
        }
        let newCorrectIndex = optionsWithIndex.findIndex(o => o.originalIndex === questionObj.correctIndex);
        return {
            options: optionsWithIndex.map(o => o.text),
            correctIndex: newCorrectIndex
        };
    }

    let currentQuestion = 0;
    let score = 0;
    let hasAnswered = false;

    const questionTextEl = document.getElementById("questionText");
    const optionsGridEl = document.getElementById("optionsGrid");
    const rationaleBoxEl = document.getElementById("rationaleBox");
    const nextBtnEl = document.getElementById("nextBtn");
    const progressTextEl = document.getElementById("progressText");

    function loadQuestion() {
        hasAnswered = false;
        rationaleBoxEl.style.display = "none";
        nextBtnEl.style.display = "none";
        optionsGridEl.innerHTML = "";
        
        let q = quizData[currentQuestion];
        progressTextEl.innerText = `Ερώτηση ${currentQuestion + 1} / ${quizData.length}`;
        questionTextEl.innerText = `${currentQuestion + 1}. ${q.question}`;

        let shuffled = shuffleOptions(q);
        q.currentCorrectMapped = shuffled.correctIndex;

        shuffled.options.forEach((optText, idx) => {
            let btn = document.createElement("button");
            btn.className = "option-btn";
            btn.innerHTML = `<strong>${String.fromCharCode(65 + idx)}.</strong>&nbsp;&nbsp;${optText}`;
            btn.onclick = () => selectAnswer(idx, q.currentCorrectMapped, btn, q.rationale);
            optionsGridEl.appendChild(btn);
        });
    }

    function selectAnswer(selectedIndex, correctIndex, btnElement, rationaleHtml) {
        if (hasAnswered) return;
        hasAnswered = true;

        const allButtons = optionsGridEl.querySelectorAll(".option-btn");
        allButtons.forEach(b => b.disabled = true);

        if (selectedIndex === correctIndex) {
            btnElement.classList.add("correct");
            score++;
        } else {
            btnElement.classList.add("wrong");
            allButtons[correctIndex].classList.add("correct");
        }

        rationaleBoxEl.innerHTML = rationaleHtml;
        rationaleBoxEl.style.display = "block";
        nextBtnEl.style.display = "block";

        if (currentQuestion === quizData.length - 1) {
            nextBtnEl.innerText = "Εμφάνιση Αποτελεσμάτων";
        }
    }

    function nextQuestion() {
        currentQuestion++;
        if (currentQuestion < quizData.length) {
            loadQuestion();
        } else {
            document.getElementById("quizScreen").style.display = "none";
            document.getElementById("resultsScreen").style.display = "block";
            document.getElementById("scoreText").innerText = score;
        }
    }

    loadQuestion();
</script>
</body>
</html>
