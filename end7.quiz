        let currentQuestionIndex = 0;

        const questionTextElement = document.getElementById('question-text');
        const optionsContainer = document.getElementById('options-container');
        const explanationContainer = document.getElementById('explanation-container');
        const explanationText = document.getElementById('explanation-text');
        const nextButton = document.getElementById('next-btn');
        const progressTracker = document.getElementById('progress-tracker');

        function loadQuestion() {
            // Reset UI
            explanationContainer.classList.remove('show');
            nextButton.classList.remove('show');
            optionsContainer.innerHTML = '';
            
            const currentQ = quizData[currentQuestionIndex];
            
            // Set Progress and Question text
            progressTracker.innerText = `Ερώτηση ${currentQuestionIndex + 1} / ${quizData.length}`;
            questionTextElement.innerText = currentQ.question;

            // Generate option buttons
            currentQ.options.forEach((option, index) => {
                const button = document.createElement('button');
                button.classList.add('option-btn');
                button.innerText = option;
                button.onclick = () => selectOption(index, button);
                optionsContainer.appendChild(button);
            });
        }

        function selectOption(selectedIndex, selectedButton) {
            const currentQ = quizData[currentQuestionIndex];
            const allOptions = optionsContainer.children;

            // Disable all buttons after selection
            for (let btn of allOptions) {
                btn.disabled = true;
            }

            // Check correct/wrong
            if (selectedIndex === currentQ.correctIndex) {
                selectedButton.classList.add('correct');
            } else {
                selectedButton.classList.add('wrong');
                // Highlight the correct one
                allOptions[currentQ.correctIndex].classList.add('correct');
            }

            // Show explanation
            explanationText.innerText = currentQ.explanation;
            explanationContainer.classList.add('show');

            // Show next button if not the last question
            if (currentQuestionIndex < quizData.length - 1) {
                nextButton.classList.add('show');
            } else {
                nextButton.innerText = "Τέλος Κουίζ";
                nextButton.onclick = () => alert("Συγχαρητήρια! Έχεις ολοκληρώσει τις ερωτήσεις.");
                nextButton.classList.add('show');
            }
        }

        function nextQuestion() {
            currentQuestionIndex++;
            loadQuestion();
        }

        // Initialize quiz
        loadQuestion();
    </script>
</body>
</html>
